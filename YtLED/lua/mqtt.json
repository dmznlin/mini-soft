{
  "enable": true,
  "host": "broker.hivemq.com",
  "port": 1883,
  "client_id": "$id$",
  "user_name": "",
  "password": "",
  "keep_alive": 240,
  "re_conn": 5000,
  "subs": {
    "own": {
      "topic": "yt202603/sub/$id$",
      "qos": 0
    }
  },
  "pubs": {
    "own": {
      "topic": "yt202603/pub/$id$",
      "qos": 0,
      "def": true
    }
  },
  "online": {
    "topic": "yt202603/pub/$id$",
    "msg": "{\"cmd\": 10, \"id\": \"$id$\"}",
    "qos": 1,
    "retain": 1
  },
  "offline": {
    "topic": "yt202603/pub/$id$",
    "msg": "{\"cmd\": 20, \"id\": \"$id$\"}",
    "qos": 1,
    "retain": 1
  }
}