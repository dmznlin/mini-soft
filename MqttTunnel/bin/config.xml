<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<znlib>
    <logger>
        <!-- 日志目录:$path表示exe路径 -->
        <filePath>$path/logs</filePath>
        <!-- 日志文件名称 -->
        <filename>app_</filename>
        <!-- 日志级别 trace,debug,info,warning,error,fatal,panic -->
        <loglevel>info</loglevel>
        <!-- 使用彩色终端 -->
        <colorful>true</colorful>
        <!-- 最长保存多少天 -->
        <max_age>30</max_age>
    </logger>
</znlib>